<Window x:Class="WinLayout.Views.DonateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="赞助" Height="350" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <Window.Resources>
        <BitmapImage x:Key="WeChatImage" UriSource="pack://application:,,,/Resources/wechat_qr.png" DecodePixelWidth="160"/>
        <BitmapImage x:Key="AlipayImage" UriSource="pack://application:,,,/Resources/alipay_qr.png" DecodePixelWidth="160"/>
    </Window.Resources>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
        <TextBlock Text="如果窗口魔方对你有帮助，欢迎赞助支持 ❤"
                   FontSize="14" TextAlignment="Center" Margin="0,0,0,15"/>
        <WrapPanel HorizontalAlignment="Center">
            <StackPanel Margin="10,0">
                <Image Source="{StaticResource WeChatImage}" Width="160"
                       Margin="0,0,0,6" HorizontalAlignment="Center"/>
                <TextBlock Text="微信" TextAlignment="Center" FontSize="13"
                           Foreground="#07C160"/>
            </StackPanel>
            <StackPanel Margin="10,0">
                <Image Source="{StaticResource AlipayImage}" Width="160"
                       Margin="0,0,0,6" HorizontalAlignment="Center"/>
                <TextBlock Text="支付宝" TextAlignment="Center" FontSize="13"
                           Foreground="#1677FF"/>
            </StackPanel>
        </WrapPanel>
    </StackPanel>
</Window>
