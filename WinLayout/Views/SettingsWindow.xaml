<Window x:Class="WinLayout.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLayout 设置" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <TabControl Margin="10">
        <TabItem Header="通用">
            <StackPanel Margin="15" Width="400">
                <TextBlock Text="修饰键" FontWeight="Bold" Margin="0,8,0,2"/>
                <ComboBox x:Name="ModifierKeyCombo">
                    <ComboBoxItem>无 (直接拖拽)</ComboBoxItem>
                    <ComboBoxItem>Shift</ComboBoxItem>
                    <ComboBoxItem>Ctrl</ComboBoxItem>
                    <ComboBoxItem>Alt</ComboBoxItem>
                    <ComboBoxItem>Shift+Ctrl</ComboBoxItem>
                    <ComboBoxItem>Shift+Alt</ComboBoxItem>
                    <ComboBoxItem>Ctrl+Alt</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="堆叠修饰键" FontWeight="Bold" Margin="0,12,0,2"/>
                <ComboBox x:Name="StackingKeyCombo" SelectedIndex="1">
                    <ComboBoxItem>Shift</ComboBoxItem>
                    <ComboBoxItem>Ctrl</ComboBoxItem>
                    <ComboBoxItem>Alt</ComboBoxItem>
                </ComboBox>

                <TextBlock Text="拖拽阈值 (px)" FontWeight="Bold" Margin="0,12,0,2"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="DragThresholdSlider" Minimum="0" Maximum="50"
                            Width="200" Value="10" TickFrequency="5" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="DragThresholdLabel" Width="40" TextAlignment="Center"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <TextBlock Text="最小窗口尺寸" FontWeight="Bold" Margin="0,12,0,2"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="MinWidthBox" Width="60" Text="200"/>
                    <TextBlock Text=" × " VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="MinHeightBox" Width="60" Text="150"/>
                </StackPanel>

                <TextBlock Text="高亮透明度" FontWeight="Bold" Margin="0,12,0,2"/>
                <StackPanel Orientation="Horizontal">
                    <Slider x:Name="HighlightOpacitySlider" Minimum="10" Maximum="80"
                            Width="200" Value="35" TickFrequency="5" IsSnapToTickEnabled="True"/>
                    <TextBlock x:Name="HighlightOpacityLabel" Width="40" Text="35%"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <CheckBox x:Name="RunAtStartupCheck" Content="开机自启"
                          Margin="0,15,0,0"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="窗口过滤">
            <StackPanel Margin="15" Width="400">
                <CheckBox x:Name="WhitelistModeCheck" Content="白名单模式（仅管理列出的应用）"
                          Margin="0,5,0,10"/>

                <TextBlock Text="进程黑名单" FontWeight="Bold" Margin="0,5,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBox x:Name="BlacklistAddBox" Width="200" Text="notepad.exe"/>
                    <Button Content="添加" Click="OnAddBlacklist" Margin="5,0,0,0" Width="50"/>
                </StackPanel>
                <ListBox x:Name="BlacklistListBox" Height="100"/>
                <Button Content="删除选中" Click="OnRemoveBlacklist" Width="70"
                        HorizontalAlignment="Left" Margin="0,5,0,0"/>
            </StackPanel>
        </TabItem>

        <TabItem Header="虚拟桌面">
            <StackPanel Margin="15" Width="400">
                <CheckBox x:Name="PerDesktopLayoutCheck" Content="各桌面独立布局"
                          Margin="0,8,0,0"/>
                <CheckBox x:Name="AutoApplyOnSwitchCheck" Content="切换桌面时自动应用布局并重排窗口"
                          Margin="0,12,0,0"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
