<Window x:Class="WinLayout.Views.LayoutEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="布局编辑器" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0">
            <Label Content="名称:"/>
            <TextBox x:Name="LayoutNameBox" Width="120" Margin="2"/>
            <Separator/>
            <Label Content="模板:"/>
            <ComboBox x:Name="TemplateCombo" Width="140" Margin="2"
                      SelectionChanged="OnTemplateSelected"/>
            <Separator/>
            <Button Content="新建" Click="OnNew" Margin="2"/>
            <Button Content="保存" Click="OnSave" Margin="2"/>
            <Button Content="删除" Click="OnDelete" Margin="2"/>
        </ToolBar>

        <!-- Preview Canvas -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="10"
                Background="#F0F0F0">
            <Canvas x:Name="PreviewCanvas" ClipToBounds="True"
                    SizeChanged="OnCanvasSizeChanged"/>
        </Border>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <TextBlock x:Name="StatusText" Text="就绪"/>
        </StatusBar>
    </Grid>
</Window>
