<Window x:Class="WinLayout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="窗口魔方" Height="560" Width="580"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="窗口魔方 — 窗口吸附布局管理器"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock x:Name="StatusLabel" Text="拖拽窗口即可吸附"
                   HorizontalAlignment="Center" Margin="0,0,0,8"
                   Foreground="Gray" TextWrapping="Wrap" TextAlignment="Center"/>
        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,8">
            <Button Content="菜单" Click="OnShowMenu"
                    Width="70" Height="32" Margin="0,0,5,0"/>
            <Button Content="打开布局编辑器" Click="OnOpenEditor"
                    Width="120" Height="32"/>
        </WrapPanel>

        <TabControl x:Name="MainTabControl" SelectionChanged="OnMainTabChanged">
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="布局收藏" FontSize="14" FontWeight="Bold" Padding="4,2"/>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <TextBlock Text="全部布局" FontWeight="Bold" Grid.Column="0" Grid.Row="0" Margin="0,0,0,3"/>
                    <TextBlock Text="收藏 (主屏)" FontWeight="Bold" Grid.Column="2" Grid.Row="0" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SecondaryHeader" Text="收藏 (副屏)" FontWeight="Bold" Grid.Column="4" Grid.Row="0" Margin="0,0,0,3" Visibility="Collapsed"/>

                    <!-- All layouts -->
                    <ListBox x:Name="AllLayoutsList" Grid.Column="0" Grid.Row="1" Height="330">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Primary buttons: → ← ⊘ -->
                    <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Top" Margin="4,50,4,0">
                        <Button Content="→" Click="OnAddPrimary" Width="30" Height="30"
                                ToolTip="添加到主屏" Margin="0,0,0,6"/>
                        <Button Content="←" Click="OnRemovePrimary" Width="30" Height="30"
                                ToolTip="从主屏移除" Margin="0,0,0,6"/>
                        <Button Content="⊘" Click="OnClearPrimary" Width="30" Height="30"
                                ToolTip="清空主屏"/>
                    </StackPanel>

                    <!-- Primary favorites -->
                    <ListBox x:Name="PrimaryFavoriteList" Grid.Column="2" Grid.Row="1" Height="330"
                             MouseDoubleClick="OnLayoutDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Secondary buttons -->
                    <StackPanel x:Name="SecondaryBtns" Grid.Column="3" Grid.Row="1"
                                VerticalAlignment="Top" Margin="4,50,4,0" Visibility="Collapsed">
                        <Button Content="→" Click="OnAddSecondary" Width="30" Height="30"
                                ToolTip="添加到副屏" Margin="0,0,0,6"/>
                        <Button Content="←" Click="OnRemoveSecondary" Width="30" Height="30"
                                ToolTip="从副屏移除" Margin="0,0,0,6"/>
                        <Button Content="⊘" Click="OnClearSecondary" Width="30" Height="30"
                                ToolTip="清空副屏"/>
                    </StackPanel>

                    <!-- Secondary favorites -->
                    <ListBox x:Name="SecondaryFavoriteList" Grid.Column="4" Grid.Row="1" Height="330"
                             MouseDoubleClick="OnLayoutDoubleClick" Visibility="Collapsed">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="快捷按钮黑名单" FontSize="14" FontWeight="Bold" Padding="4,2"/>
                </TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <TextBlock Text="运行中应用" FontWeight="Bold"
                               Grid.Column="0" Grid.Row="0" Margin="0,0,0,3"/>
                    <TextBlock Text="黑名单" FontWeight="Bold"
                               Grid.Column="2" Grid.Row="0" Margin="0,0,0,3"/>

                    <!-- Running apps list -->
                    <ListBox x:Name="RunningAppsList" Grid.Column="0" Grid.Row="1" Height="330">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Icon}" Width="16" Height="16"
                                           Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Buttons: → ← ⊘ -->
                    <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Top"
                                Margin="4,50,4,0">
                        <Button Content="→" Click="OnAddToButtonBlacklist" Width="30" Height="30"
                                ToolTip="添加快捷按钮黑名单" Margin="0,0,0,6"/>
                        <Button Content="←" Click="OnRemoveFromButtonBlacklist" Width="30" Height="30"
                                ToolTip="从快捷按钮黑名单移除" Margin="0,0,0,6"/>
                        <Button Content="⊘" Click="OnClearButtonBlacklist" Width="30" Height="30"
                                ToolTip="清空快捷按钮黑名单"/>
                    </StackPanel>

                    <!-- Blacklist -->
                    <ListBox x:Name="ButtonBlacklistList" Grid.Column="2" Grid.Row="1" Height="330">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding Icon}" Width="16" Height="16"
                                           Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>
