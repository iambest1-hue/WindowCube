<Window x:Class="WinLayout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLayout" Height="420" Width="380"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="WinLayout — 窗口吸附布局管理器"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock x:Name="StatusLabel" Text="拖拽窗口即可吸附"
                   HorizontalAlignment="Center" Margin="0,0,0,10"
                   Foreground="Gray"/>
        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="菜单" Click="OnShowMenu"
                    Width="70" Height="35" Margin="0,0,5,0"/>
            <Button Content="打开布局编辑器" Click="OnOpenEditor"
                    Width="120" Height="35"/>
        </WrapPanel>
        <TextBlock Text="收藏的布局" FontWeight="Bold" Margin="0,5,0,5"/>
        <Border BorderBrush="LightGray" BorderThickness="1" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FavoriteList" Margin="5"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
</Window>
