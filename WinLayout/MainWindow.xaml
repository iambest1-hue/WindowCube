<Window x:Class="WinLayout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLayout" Height="200" Width="350"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20" VerticalAlignment="Center">
        <TextBlock Text="WinLayout — 窗口吸附布局管理器"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock x:Name="StatusLabel" Text="Shift+拖拽窗口吸附就绪"
                   HorizontalAlignment="Center" Margin="0,0,0,15"
                   Foreground="Gray"/>
        <Button Content="打开布局编辑器" Click="OnOpenEditor"
                Width="150" Height="35" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <Button Content="测试叠加层" Click="OnTestOverlay"
                Width="150" Height="35" HorizontalAlignment="Center"
                Background="Orange" Margin="0,5,0,0"/>
    </StackPanel>
</Window>
