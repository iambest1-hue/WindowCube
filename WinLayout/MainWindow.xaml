<Window x:Class="WinLayout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLayout" Height="550" Width="520"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="WinLayout — 窗口吸附布局管理器"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock x:Name="StatusLabel" Text="拖拽窗口即可吸附"
                   HorizontalAlignment="Center" Margin="0,0,0,10"
                   Foreground="Gray"/>
        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="菜单" Click="OnShowMenu"
                    Width="70" Height="35" Margin="0,0,5,0"/>
            <Button Content="打开布局编辑器" Click="OnOpenEditor"
                    Width="120" Height="35"/>
        </WrapPanel>
        <Grid Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="全部布局" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,3"/>
            <ListBox x:Name="AllLayoutsList" Grid.Row="1" Grid.Column="0" Height="320">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Primary favorites row -->
            <TextBlock Text="收藏 (主屏)" FontWeight="Bold" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,3"/>
            <Button Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="4,40,4,0"
                    Content="→" Click="OnAddPrimary" Width="28" Height="28" ToolTip="添加到主屏收藏"/>
            <ListBox x:Name="PrimaryFavoriteList" Grid.Row="1" Grid.Column="2" Height="130"
                     MouseDoubleClick="OnLayoutDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="1" Grid.Column="3" VerticalAlignment="Top" Margin="2,40,0,0">
                <Button Content="←" Click="OnRemovePrimary" Width="28" Height="28"
                        ToolTip="从主屏收藏移除" Margin="0,0,0,4"/>
                <Button Content="⊘" Click="OnClearPrimary" Width="28" Height="28"
                        ToolTip="清空主屏收藏（保留一项）"/>
            </StackPanel>

            <!-- Secondary favorites row -->
            <TextBlock x:Name="SecondaryFavLabel" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                       Text="收藏 (副屏)" FontWeight="Bold" Margin="0,8,0,3" Visibility="Collapsed"/>
            <Button x:Name="AddSecondaryBtn" Grid.Row="4" Grid.Column="1" VerticalAlignment="Top"
                    Margin="4,40,4,0" Content="→" Click="OnAddSecondary" Width="28" Height="28"
                    ToolTip="添加到副屏收藏" Visibility="Collapsed"/>
            <ListBox x:Name="SecondaryFavoriteList" Grid.Row="4" Grid.Column="2" Height="130"
                     MouseDoubleClick="OnLayoutDoubleClick" Visibility="Collapsed">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel x:Name="SecondaryBtns" Grid.Row="4" Grid.Column="3"
                        VerticalAlignment="Top" Margin="2,40,0,0" Visibility="Collapsed">
                <Button Content="←" Click="OnRemoveSecondary" Width="28" Height="28"
                        ToolTip="从副屏收藏移除" Margin="0,0,0,4"/>
                <Button Content="⊘" Click="OnClearSecondary" Width="28" Height="28"
                        ToolTip="清空副屏收藏（保留一项）"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>
