<Window x:Class="WinLayout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLayout" Height="520" Width="480"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="WinLayout — 窗口吸附布局管理器"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock x:Name="StatusLabel" Text="拖拽窗口即可吸附"
                   HorizontalAlignment="Center" Margin="0,0,0,10"
                   Foreground="Gray"/>
        <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="菜单" Click="OnShowMenu"
                    Width="70" Height="35" Margin="0,0,5,0"/>
            <Button Content="打开布局编辑器" Click="OnOpenEditor"
                    Width="120" Height="35"/>
        </WrapPanel>
        <Grid Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="全部布局" FontWeight="Bold" Grid.Column="0" Grid.Row="0" Margin="0,0,0,3"/>
            <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
                <TextBlock x:Name="PrimaryFavLabel" Text="收藏的布局 (主屏)" FontWeight="Bold" Margin="0,0,0,3"/>
                <ListBox x:Name="PrimaryFavoriteList" Height="120"
                         MouseDoubleClick="OnLayoutDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="SecondaryFavLabel" Text="收藏的布局 (副屏)" FontWeight="Bold"
                           Margin="0,8,0,3" Visibility="Collapsed"/>
                <ListBox x:Name="SecondaryFavoriteList" Height="120"
                         MouseDoubleClick="OnLayoutDoubleClick" Visibility="Collapsed">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
            <ListBox x:Name="AllLayoutsList" Grid.Column="0" Grid.Row="1"
                     Height="290" MouseDoubleClick="OnLayoutDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="8,0">
                <Button Content="→" Click="OnAddFavorite" Width="36" Height="28"
                        ToolTip="添加到收藏" Margin="0,0,0,5"/>
                <Button Content="←" Click="OnRemoveFavorite" Width="36" Height="28"
                        ToolTip="从收藏移除" Margin="0,0,0,5"/>
                <Button Content="⊘" Click="OnClearFavorites" Width="36" Height="28"
                        ToolTip="全部移除（保留第一项）"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>
